ENVIRONMENT=dev

# Server
HOST=127.0.0.1
PORT=8000

# Database
DATABASE_URL="postgres://root:root@localhost/axum_example"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=3600

# Session (hours)
AUTH_SESSION_EXPIRE_TIME=24
AUTH_EMAIL_VERIFICATION_TOKEN_EXPIRE_TIME=1
AUTH_PASSWORD_RESET_TOKEN_EXPIRE_TIME=1

# Rate Limit
LOGIN_RATE_LIMIT=10
API_RATE_LIMIT=100

# Session Cleanup (seconds, default: 3600 = 1 hour)
SESSION_CLEANUP_INTERVAL=3600

# Enable file logging (logs/app.log) - default: false
ENABLE_FILE_LOGGING=false

# SQLx Query Logging - default: false, level: Info
SQLX_LOGGING=false

# SQLx Log Level (debug, info, warn, error, trace, off) - default: info
SQLX_LOG_LEVEL=info

# Cookies seguros (requer HTTPS)
COOKIE_SECURE=false

# Bloqueio por tentativas de login
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15